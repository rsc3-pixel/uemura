# Copie este arquivo para .env e preencha com as credenciais reais.
# O .env nunca vai para o Git (ver .gitignore).

# Token do Mercado Pago.
# Sandbox (testes) comeca com TEST-
# Producao comeca com APP_USR-
MP_ACCESS_TOKEN=

# Senha das rotas administrativas (aprovar pagamento, avancar status da entrega).
# Sem esta variavel, essas rotas ficam DESATIVADAS (padrao seguro para producao,
# onde a aprovacao real chega pelo webhook do Mercado Pago).
# Para rodar o demo local, escolha qualquer valor e repita em .env.local na raiz.
ADMIN_TOKEN=

# Origem permitida no CORS. Em producao, o dominio do front-end
# (ex.: https://uemurafloresplantas.com.br). Em branco = libera qualquer origem (so dev).
CORS_ORIGIN=

# Porta do servidor Express (padrao 3001)
PORT=3001
